<?xml version="1.0" encoding="utf-8"?>
<!--
    Иконка в стиле неонового контура на чёрном фоне.
    Градиент: cyan → blue → purple → pink → orange → yellow-green
    (по аналогии с референсным фото)
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Чёрный фон -->
    <path
        android:fillColor="#000000"
        android:pathData="M0,0 L108,0 L108,108 L0,108 Z" />

    <!-- Градиентные определения через group + color trick:
         Рисуем контур скруглённого квадрата и "стрелка-бумеранг" внутри
         через overlapping полосы разных цветов, создавая эффект градиента -->

    <!-- ═══ ВНЕШНИЙ КОНТУР (скруглённый квадрат) ════════════════════
         Разбиваем периметр на 4 дуги по цветам градиента           -->

    <!-- Верхняя сторона: cyan → blue -->
    <path
        android:strokeColor="#00EFFF"
        android:strokeWidth="4.5"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M28,18 L80,18" />
    <!-- Верхний правый угол: blue → purple -->
    <path
        android:strokeColor="#7B4CFF"
        android:strokeWidth="4.5"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M80,18 Q92,18 92,30" />
    <!-- Правая сторона: purple → pink -->
    <path
        android:strokeColor="#DD44FF"
        android:strokeWidth="4.5"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M92,30 L92,78" />
    <!-- Нижний правый угол: pink → orange -->
    <path
        android:strokeColor="#FF6622"
        android:strokeWidth="4.5"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M92,78 Q92,90 80,90" />
    <!-- Нижняя сторона: orange → yellow-green -->
    <path
        android:strokeColor="#AAFF00"
        android:strokeWidth="4.5"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M80,90 L28,90" />
    <!-- Нижний левый угол: yellow-green → cyan -->
    <path
        android:strokeColor="#00EFFF"
        android:strokeWidth="4.5"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M28,90 Q16,90 16,78" />
    <!-- Левая сторона нижняя часть: cyan -->
    <path
        android:strokeColor="#00CCFF"
        android:strokeWidth="4.5"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M16,78 L16,60" />
    <!-- Разрыв на левой стороне (как на фото) -->
    <path
        android:strokeColor="#00BBFF"
        android:strokeWidth="4.5"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M16,50 L16,30" />
    <!-- Верхний левый угол: cyan -->
    <path
        android:strokeColor="#00EFFF"
        android:strokeWidth="4.5"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M16,30 Q16,18 28,18" />

    <!-- Маленький штрих-разрыв на левой стороне (как на фото — короткий вертикальный отрезок) -->
    <path
        android:strokeColor="#00EFFF"
        android:strokeWidth="4.5"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M16,54 L16,58" />

    <!-- ═══ ДИАГОНАЛЬНАЯ ЛИНИЯ (основа стрелки) ══════════════════════
         От нижнего левого к верхнему правому — cyan → purple         -->
    <path
        android:strokeColor="#7B4CFF"
        android:strokeWidth="4.5"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M26,82 L82,30" />

    <!-- ═══ СТРЕЛКА (треугольник) в центре-правой части ════════════
         pink → orange                                               -->
    <!-- Левая сторона треугольника -->
    <path
        android:strokeColor="#FF44BB"
        android:strokeWidth="4.5"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M66,36 L46,56" />
    <!-- Правая / нижняя сторона треугольника -->
    <path
        android:strokeColor="#FF6622"
        android:strokeWidth="4.5"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M86,28 L66,36 L76,56" />

    <!-- ═══ НИЖНЯЯ ЛИНИЯ диагонали продолжение (cyan) ════════════ -->
    <path
        android:strokeColor="#00EFFF"
        android:strokeWidth="4.5"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M26,82 L68,78" />

</vector>
